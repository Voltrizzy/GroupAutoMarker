<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/
..\FrameXML\UI.xsd">
    <!-- This is the hidden helper button that does the actual work. -->
    <Button name="GAM_HelperButton" hidden="true">
        <Scripts>
            <OnClick>
                GroupAutoMarker.ApplyMarkers()
            </OnClick>
        </Scripts>
    </Button>

    <!-- This is the visible, clickable icon for the player. -->
    <Button name="GAM_IconButton" parent="UIParent" frameStrata="MEDIUM" hidden="true" inherits="SecureActionButtonTemplate">
        <Size x="36" y="36"/>
        <Anchors>
            <Anchor point="CENTER" x="0" y="200"/>
        </Anchors>
        <Attributes>
            <Attribute name="type" type="string" value="macro"/>
            <Attribute name="macrotext" type="string" value="/click GAM_HelperButton"/>
        </Attributes>
        <NormalTexture file="Interface\TargetingFrame\UI-TargetingFrame-Skull"/>
        <PushedTexture file="Interface\TargetingFrame\UI-TargetingFrame-Skull">
            <Color r="0.8" g="0.8" b="0.8"/>
        </PushedTexture>
        <HighlightTexture file="Interface\Buttons\ButtonHilight-Square" alphaMode="ADD"/>
    </Button>
</Ui>
